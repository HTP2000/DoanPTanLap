                    <i class="fa-solid fa-monument"></i>
                </div>
            </div>
            <div id="vanhoa-list" class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8"></div>
        </section>

        <section id="to-dan-pho" class="scroll-mt-24 pb-12">
