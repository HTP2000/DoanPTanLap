---
import '../styles/global.css';
import { sanityClient } from "sanity:client";

// ==========================================================
// 1. KÉO TOÀN BỘ DỮ LIỆU TỪ SANITY VỀ ASTRO
// ==========================================================
const { rawCoQuanData, vanHoaData, tdpData } = await sanityClient.fetch(`{
  "rawCoQuanData": *[_type == "coQuanNhaNuoc"] | order(order asc) {
    "id": _id, title, theme, unitLabel, roomLabel, description, address, mapLink,
    "image": image.asset->url,
    departments[] { 
        name, personName, nameColor, nameWeight, nameStyle, nameSize, 
        roleColor, roleWeight, roleStyle, roleSize,
        roles, address 
    }
  },
  "vanHoaData": *[_type == "diemVanHoa"] | order(order asc) {
    "id": _id, title, description, address, mapLink,
    "image": image.asset->url,
    gallery[] { "image": image.asset->url, caption }
  },
  "tdpData": *[_type == "hoiTruong"] | order(order asc) {
    "id": _id, badge, address, mapLink
  }
}`);

// Xử lý dữ liệu Portable Text (Chữ in đậm, xuống dòng) của Sanity thành HTML
const coQuanData = rawCoQuanData.map((coquan: any) => {
    return {
        ...coquan,
        departments: (coquan.departments || []).map((dept: any) => {
            let rolesHtml = '';
            if (dept.roles && Array.isArray(dept.roles)) {
                rolesHtml = dept.roles.map((block: any) => {
                    if (block._type !== 'block' || !block.children) return '';
                    let pContent = block.children.map((child: any) => {
                        let text = child.text || '';
                        if (child.marks && child.marks.includes('strong')) text = `<strong>${text}</strong>`;
                        if (child.marks && child.marks.includes('em')) text = `<em>${text}</em>`;
                        return text;
                    }).join('');
                    return `<div class="mb-1">${pContent}</div>`;
                }).join('');
            }
            return { ...dept, rolesHtml };
        })
    }
});

// ==========================================================
// 2. DỮ LIỆU TĨNH GLOBAL
// ==========================================================
const globalData = {
    // Đã sửa lại đường dẫn HTML chuẩn để logo hiển thị
    logo: '<img src="/assets/logodoan.png" alt="Logo" class="w-full h-full object-contain drop-shadow-md">', 
    titleLine1: "ĐOÀN TNCS HỒ CHÍ MINH PHƯỜNG TÂN LẬP",
    titleLine2: "",
    subtitles: [
        'Thanh Niên Xung Kích - Sáng Tạo Chuyển Đổi Số', 
        'Thông Tin Nhanh Chóng - Tiện Ích', 
        'Chuyển Đổi Số - Phục Vụ Nhân Dân', 
    ],
    footerText: "Công trình Thanh Niên Địa Phương Số"
};
---

