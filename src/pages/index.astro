    <footer class="bg-slate-900 text-slate-300 py-12 text-center border-t-4 border-brand-blue relative">
        <div class="max-w-4xl mx-auto px-4">
            <h3 id="app-footer" class="font-bold text-lg md:text-xl text-white mb-2 uppercase tracking-wide"></h3>
            <p class="text-sm text-slate-400 mb-6">Được thực hiện bởi Đoàn TNCS Hồ Chí Minh Phường Tân Lập</p>
            <div class="flex justify-center gap-4">
                <a href="https://www.facebook.com/share/1CSq8WCGVH/?mibextid=wwXIfr" target="_blank" title="Facebook Đoàn Phường" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-blue-600 hover:text-white transition-all"><i class="fa-brands fa-facebook-f"></i></a>
                <a href="https://www.tiktok.com/@doanphuongtanlap_?_r=1&_t=ZS-95Zb9dLBsUU" target="_blank" title="Tiktok Đoàn Phường" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-black hover:text-white transition-all"><i class="fa-brands fa-tiktok"></i></a>
            </div>
        </div>
    </footer>

    <div id="departmentModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity duration-300" onclick="closeModal()"></div>
        <div id="modalContent" class="relative bg-[#f8fafc] rounded-2xl sm:rounded-3xl shadow-2xl border border-white/50 w-[95vw] sm:w-[90vw] max-w-6xl h-[90vh] sm:h-[85vh] p-4 sm:p-8 transform scale-90 opacity-0 transition-all duration-500 ease-out flex flex-col overflow-hidden">
            <button onclick="closeModal()" class="absolute top-4 right-4 z-20 w-10 h-10 flex items-center justify-center rounded-full bg-white hover:bg-red-500 hover:text-white text-slate-600 shadow-md transition-all duration-300 group">
                <i class="fa-solid fa-times text-xl group-hover:rotate-90 transition-transform duration-300"></i>
            </button>
            <div class="border-b border-slate-200 pb-4 mb-4 sm:mb-6 pr-12 flex-shrink-0 relative z-10">
                <h3 id="modalTitle" class="text-xl sm:text-2xl md:text-3xl font-extrabold text-brand-blue leading-snug">Tiêu đề</h3>
                <p id="modalSubtitle" class="text-sm text-slate-500 mt-2 font-medium">Mô tả phụ</p>
            </div>
            <div class="overflow-y-auto pr-2 custom-scrollbar flex-1 pb-4 relative z-10">
                <div id="modalList"></div>
            </div>
            <div class="absolute bottom-0 right-0 w-64 h-64 bg-brand-light rounded-tl-full opacity-50 pointer-events-none z-0"></div>
        </div>
    </div>

    <script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script is:inline src="https://unpkg.com/typed.js@2.1.0/dist/typed.umd.js"></script>

    <script is:inline define:vars={{ coQuanData, vanHoaData, tdpData, globalData }}>
        
        const ASSETS = {
            global: globalData,
            coQuanNhaNuoc: coQuanData,
            diemVanHoa: vanHoaData,
            diemHoiTruong: tdpData
        };

        const departmentData = {};
        ASSETS.coQuanNhaNuoc.forEach(item => {
            departmentData[item.id] = { 
                title: item.title, 
                departments: item.departments, 
                theme: item.theme,
                unitLabel: item.unitLabel || "Đồng chí",
                roomLabel: item.roomLabel || "Tầng / Phòng"
            };
        });

        const themeColors = {
            blue: { text: 'text-blue-600', bg: 'bg-blue-50', badge: 'bg-blue-100 text-blue-700' },
            red: { text: 'text-red-600', bg: 'bg-red-50', badge: 'bg-red-100 text-red-700' },
            green: { text: 'text-emerald-600', bg: 'bg-emerald-50', badge: 'bg-emerald-100 text-emerald-700' },
            yellow: { text: 'text-amber-600', bg: 'bg-amber-50', badge: 'bg-amber-100 text-amber-700' }
        };

        document.addEventListener("DOMContentLoaded", () => {
            // Mobile Menu
            const mobileBtn = document.getElementById('mobile-menu-btn');
            const mobileIcon = document.getElementById('mobile-menu-icon');
            const mobileMenu = document.getElementById('mobile-menu');
            const mobileLinks = document.querySelectorAll('.mobile-link');

            mobileBtn.addEventListener('click', () => {
                const isHidden = mobileMenu.classList.contains('hidden');
                if(isHidden) {
                    mobileMenu.classList.remove('hidden');
                    mobileMenu.classList.add('flex');
                    mobileIcon.classList.remove('fa-bars');
                    mobileIcon.classList.add('fa-xmark'); 
                } else {
                    mobileMenu.classList.add('hidden');
                    mobileMenu.classList.remove('flex');
                    mobileIcon.classList.remove('fa-xmark');
                    mobileIcon.classList.add('fa-bars'); 
                }
            });

            mobileLinks.forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenu.classList.add('hidden');
                    mobileMenu.classList.remove('flex');
                    mobileIcon.classList.remove('fa-xmark');
                    mobileIcon.classList.add('fa-bars');
                });
            });

            document.getElementById('app-logo-container').innerHTML = ASSETS.global.logo;
            document.getElementById('app-title-line1').innerHTML = ASSETS.global.titleLine1;
            document.getElementById('app-title-line2').innerHTML = ASSETS.global.titleLine2;
            document.getElementById('app-footer').innerText = ASSETS.global.footerText;

            // Render Mục 1: Cơ quan nhà nước (Từ Sanity)
            const nhaNuocContainer = document.getElementById('nhanuoc-list');
            ASSETS.coQuanNhaNuoc.forEach((item, index) => {
                const t = themeColors[item.theme] || themeColors.blue;
                nhaNuocContainer.innerHTML += `
                    <div class="group bg-white rounded-3xl shadow-sm hover:shadow-2xl transition-all duration-500 overflow-hidden border border-slate-100 flex flex-col h-full transform hover:-translate-y-2 cursor-pointer" data-aos="fade-up" data-aos-delay="${(index+1)*100}" onclick="openModal('${item.id}', 'nhanuoc')">
                        <div class="relative h-48 sm:h-56 overflow-hidden bg-slate-100">
                            <img src="${item.image}" alt="${item.title}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out" onerror="this.onerror=null;this.src='https://placehold.co/600x400/e2e8f0/64748b?text=Hình+ảnh';">
                            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/20 to-transparent"></div>
                            <h3 class="absolute bottom-4 left-4 right-4 text-white font-bold text-xl drop-shadow-md leading-tight">${item.title}</h3>
                        </div>
                        <div class="p-5 flex-1 flex flex-col relative">
                            <div class="absolute top-0 right-4 w-12 h-12 rounded-full ${t.bg} ${t.text} flex items-center justify-center -translate-y-1/2 shadow-sm border-4 border-white group-hover:rotate-12 transition-transform">
                                <i class="fa-solid fa-building text-lg"></i>
                            </div>
                            <p class="text-slate-600 text-sm flex-1 mb-4 mt-2 line-clamp-3">${item.description || ''}</p>
                            ${item.address ? `
                            <a href="${item.mapLink || '#'}" target="_blank" onclick="event.stopPropagation()" class="mt-auto bg-slate-50 hover:bg-slate-100 p-3 rounded-2xl flex items-center gap-3 transition-colors group/map">
                                <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center text-red-500 shadow-sm group-hover/map:bg-red-500 group-hover/map:text-white transition-colors">
                                    <i class="fa-solid fa-location-dot"></i>
                                </div>
                                <span class="text-xs font-medium text-slate-700 flex-1 truncate">${item.address}</span>
                                <i class="fa-solid fa-arrow-right text-slate-400 group-hover/map:text-red-500 group-hover/map:translate-x-1 transition-all"></i>
                            </a>` : ''}
                        </div>
                    </div>`;
            });

            // Render Mục 2: Điểm Văn Hóa (Từ Sanity)
            const vanHoaContainer = document.getElementById('vanhoa-list');
            ASSETS.diemVanHoa.forEach((item, index) => {
                vanHoaContainer.innerHTML += `
                    <div class="group flex flex-col sm:flex-row bg-white rounded-3xl shadow-sm hover:shadow-2xl transition-all duration-500 overflow-hidden border border-slate-100 transform hover:-translate-y-2 cursor-pointer" data-aos="fade-up" data-aos-delay="${(index+1)*100}" onclick="openModal('${item.id}', 'vanhoa')">
                        <div class="sm:w-2/5 h-56 sm:h-auto relative overflow-hidden bg-slate-100 shrink-0">
                            <img src="${item.image}" alt="${item.title}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out" onerror="this.onerror=null;this.src='https://placehold.co/600x800/e2e8f0/64748b?text=Ảnh+Minh+Hoạ';">
                            <div class="absolute inset-0 bg-brand-blue/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                        </div>
                        <div class="p-6 flex-1 flex flex-col justify-center">
                            <div class="inline-block px-3 py-1 bg-brand-light text-brand-blue rounded-full text-xs font-bold mb-3 w-max">Điểm Di Tích / Văn Hóa</div>
                            <h3 class="text-xl font-bold text-slate-800 mb-2 group-hover:text-brand-blue transition-colors">${item.title}</h3>
                            <p class="text-slate-600 text-sm mb-4 line-clamp-3">${item.description}</p>
                            <a href="${item.mapLink}" target="_blank" onclick="event.stopPropagation()" class="mt-auto inline-flex items-center gap-2 text-sm text-brand-blue font-semibold hover:text-brand-dark group/link">
                                <i class="fa-solid fa-map-location-dot"></i> Xem trên bản đồ
                                <i class="fa-solid fa-arrow-right-long opacity-0 -ml-2 group-hover/link:opacity-100 group-hover/link:ml-1 transition-all"></i>
                            </a>
                        </div>
                    </div>`;
            });

            // Render Mục 3: Hội trường (Từ Sanity)
            const hoiTruongContainer = document.getElementById('hoitruong-list');
            ASSETS.diemHoiTruong.forEach((item, index) => {
                let delay = (index % 3) * 100; 
                hoiTruongContainer.innerHTML += `
                    <a href="${item.mapLink}" target="_blank" class="block bg-white rounded-2xl p-4 sm:p-5 shadow-sm border border-slate-100 relative overflow-hidden flex flex-col hover:shadow-lg hover:shadow-blue-900/10 hover:-translate-y-2 hover:border-brand-blue/30 transition-all duration-300 cursor-pointer group" data-aos="fade-up" data-aos-delay="${delay}">
                        <div class="absolute top-0 right-0 w-24 h-24 sm:w-32 sm:h-32 bg-blue-50/70 rounded-bl-full -z-0 group-hover:scale-125 transition-transform duration-500"></div>
                        <div class="relative z-10 flex flex-col h-full">
                            <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-brand-light text-brand-blue rounded-full text-[10px] sm:text-xs font-semibold mb-3 sm:mb-4 w-fit">
                                <i class="fa-solid fa-location-dot"></i>
                                <span>${item.badge}</span>
                            </div>
                            <div class="flex items-start gap-2 sm:gap-3 text-xs sm:text-sm">
                                <i class="fa-solid fa-location-dot text-slate-400 mt-1 w-3 sm:w-4 text-center"></i>
                                <div><span class="text-slate-500 block text-[10px] sm:text-[11px] mb-0.5 uppercase tracking-wide">Địa chỉ:</span><span class="text-slate-800 font-medium">${item.address}</span></div>
                            </div>
                        </div>
                    </a>`;
            });

            new Typed('#typed-subtitle', {
                strings: ASSETS.global.subtitles,
                typeSpeed: 60, backSpeed: 30, backDelay: 2500, loop: true
            });

            AOS.init({ duration: 800, once: true, offset: 50 });
        });

        // =========================================================================
        // XỬ LÝ MODAL (CẬP NHẬT CHO SANITY & CÁC TÙY CHỈNH STYLE)
        // =========================================================================
        const modal = document.getElementById('departmentModal');
        const modalContent = document.getElementById('modalContent');
        const modalTitle = document.getElementById('modalTitle');
        const modalSubtitle = document.getElementById('modalSubtitle');
        const modalList = document.getElementById('modalList');

        window.openModal = function(itemId, type) {
            modalList.innerHTML = '';
            
            if (type === 'nhanuoc') {
                const data = departmentData[itemId];
                if (!data) return;
                
                modalTitle.textContent = data.title;
                modalSubtitle.textContent = "Sơ đồ các phòng ban & Cán bộ phụ trách";
                modalList.className = "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 pb-6";

                (data.departments || []).forEach((dept, index) => {
                    const card = document.createElement('div');
                    card.className = 'bg-white rounded-2xl p-5 shadow-sm border border-slate-100 relative overflow-hidden group hover:shadow-md transition-all duration-300 cursor-pointer hover:border-brand-blue/30';
                    
                    // Lấy style cho Tên
                    let nColor = dept.nameColor || 'text-brand-blue';
                    let nWeight = dept.nameWeight || 'font-bold';
                    let nStyle = dept.nameStyle || 'not-italic';
                    let nSize = dept.nameSize || 'text-base';

                    // Lấy style cho Chức danh
                    let rColor = dept.roleColor || 'text-slate-500';
                    let rWeight = dept.roleWeight || 'font-normal';
                    let rStyle = dept.roleStyle || 'italic';
                    let rSize = dept.roleSize || 'text-xs';

                    // Xử lý Tên cán bộ (từ Sanity kèm style tùy chỉnh)
                    let nameHtml = dept.personName 
                        ? `<span class="${nColor} ${nWeight} ${nStyle} ${nSize} uppercase block mb-1">${dept.personName}</span>` 
                        : '';
                    
                    // Xử lý Chức danh (từ Sanity - đã parse HTML trên server)
                    let rolesHtml = dept.rolesHtml || '';

                    card.innerHTML = `
                        <div class="absolute top-0 left-0 w-1 h-full bg-brand-blue opacity-50 group-hover:opacity-100 group-hover:w-2 transition-all duration-300"></div>
                        <div class="pl-3">
                            <h4 class="font-bold text-slate-800 text-base mb-3 border-b border-slate-50 pb-2">${dept.name}</h4>
                            <div class="flex flex-col gap-3 text-sm">
                                ${nameHtml || rolesHtml ? `
                                <div class="flex items-start gap-3">
                                    <div class="w-6 h-6 rounded-full bg-blue-50 text-brand-blue flex items-center justify-center shrink-0 mt-0.5"><i class="fa-solid fa-user-tie text-xs"></i></div>
                                    <div>
                                        <span class="text-slate-400 block text-[10px] uppercase font-bold tracking-wider mb-0.5">${data.unitLabel}</span>
                                        ${nameHtml}
                                        <div class="${rColor} ${rWeight} ${rStyle} ${rSize} leading-snug">
                                            ${rolesHtml}
                                        </div>
                                    </div>
                                </div>` : ''}
                                ${dept.address ? `
                                <div class="flex items-start gap-3">
                                    <div class="w-6 h-6 rounded-full bg-slate-100 text-slate-500 flex items-center justify-center shrink-0 mt-0.5"><i class="fa-solid fa-door-open text-xs"></i></div>
                                    <div><span class="text-slate-400 block text-[10px] uppercase font-bold tracking-wider mb-0.5">${data.roomLabel}</span><span class="text-slate-700 block">${dept.address}</span></div>
                                </div>` : ''}
                            </div>
                        </div>`;
                    card.style.opacity = '0';
                    card.style.animation = `fadeInUp 0.4s ease forwards ${index * 0.05}s`;
                    modalList.appendChild(card);
                });
            } 
            else if (type === 'vanhoa') {
                const data = ASSETS.diemVanHoa.find(item => item.id === itemId);
                if (!data) return;

                modalTitle.textContent = data.title;
                modalSubtitle.textContent = "Thông tin chi tiết di tích / điểm văn hóa";
                modalList.className = "flex flex-col gap-6 pb-6";
                
                let galleryHTML = (data.gallery && data.gallery.length > 0) ? `
                    <div class="mt-4">
                        <h4 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2"><i class="fa-solid fa-images text-brand-blue"></i> Thư viện hình ảnh</h4>
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                            ${data.gallery.map(img => `
                                <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden group/img cursor-pointer hover:shadow-md transition-all duration-300 hover:border-brand-blue/30">
                                    <div class="aspect-[4/3] overflow-hidden bg-slate-100"><img src="${img.image || img}" alt="${img.caption || 'Hình ảnh'}" class="w-full h-full object-cover group-hover/img:scale-110 transition-transform duration-700" onerror="this.onerror=null;this.src='https://placehold.co/500x375/e2e8f0/64748b?text=Hinh+Anh';"></div>
                                    <div class="p-3 bg-white text-center"><p class="text-sm font-medium text-slate-700">${img.caption || ''}</p></div>
                                </div>`).join('')}
                        </div>
                    </div>` : '';

                const card = document.createElement('div');
                card.className = "animate-[fadeInUp_0.4s_ease_forwards]";
                card.innerHTML = `
                    <div class="bg-white p-6 md:p-8 rounded-3xl border border-slate-100 shadow-sm relative overflow-hidden cursor-pointer hover:shadow-md transition-all duration-300 hover:border-brand-blue/30">
                        <div class="absolute top-0 right-0 w-32 h-32 bg-brand-light rounded-bl-full -z-0 opacity-50"></div>
                        <div class="relative z-10">
                            <h4 class="text-lg font-bold text-slate-800 mb-3"><i class="fa-solid fa-circle-info text-brand-blue mr-2"></i>Giới thiệu chung</h4>
                            <p class="text-slate-600 leading-relaxed text-base md:text-lg text-justify mb-6">${data.description}</p>
                            ${data.address ? `
                            <div class="inline-flex flex-col sm:flex-row sm:items-center gap-4 bg-slate-50 p-4 rounded-2xl border border-slate-100 w-full sm:w-auto">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center text-red-500 shrink-0"><i class="fa-solid fa-location-dot"></i></div>
                                    <div><span class="block text-[10px] text-slate-400 uppercase font-bold tracking-wider">Địa chỉ</span><span class="font-medium text-sm text-slate-800">${data.address}</span></div>
                                </div>
                                <a href="${data.mapLink}" target="_blank" class="sm:ml-auto w-full sm:w-auto text-center px-4 py-2 bg-brand-blue text-white text-sm font-semibold rounded-xl hover:bg-brand-dark transition-colors shadow-sm">Chỉ đường</a>
                            </div>` : ''}
                        </div>
                    </div>
                    ${galleryHTML}`;
                modalList.appendChild(card);
            }

            modal.classList.remove('hidden');
            setTimeout(() => {
                modalContent.classList.remove('scale-90', 'opacity-0');
                modalContent.classList.add('scale-100', 'opacity-100');
            }, 10);
            history.pushState({ modalOpen: true }, '');
        };

        window.closeModal = function(isFromPopState = false) {
            modalContent.classList.remove('scale-100', 'opacity-100');
            modalContent.classList.add('scale-90', 'opacity-0');
            setTimeout(() => {
                modal.classList.add('hidden');
                modalList.innerHTML = ''; 
            }, 300);
            if (isFromPopState !== true && history.state && history.state.modalOpen) {
                history.back();
            }
        };

        document.addEventListener('keydown', (event) => {
            if (!modal.classList.contains('hidden')) {
                if (event.key === 'Escape' || event.key === 'Backspace') {
                    event.preventDefault(); 
                    window.closeModal();
                }
            }
        });

        window.addEventListener('popstate', (event) => {
            if (!modal.classList.contains('hidden')) {
                window.closeModal(true); 
            }
        });
        
    </script>

    <div id="chatbot-container" class="fixed bottom-6 right-6 z-50 flex flex-col items-end">
        
        <div id="chat-window" class="hidden w-80 sm:w-96 bg-white rounded-2xl shadow-2xl border border-slate-200 mb-4 overflow-hidden flex-col h-[500px] max-h-[80vh] transition-all duration-300 transform scale-95 opacity-0 origin-bottom-right">
            <div class="bg-brand-blue p-4 flex items-center justify-between text-white">
                <div class="flex items-center gap-3">
                    <div class="relative">
                        <img src="/assets/logodoan.png" alt="Logo" class="w-8 h-8 object-contain drop-shadow-md">
                        <div class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-400 rounded-full border-2 border-brand-blue"></div>
                    </div>
                    <div>
                        <h4 class="font-bold text-sm">Trợ lý ảo Đoàn Phường</h4>
                        <p class="text-[10px] text-blue-200">Đang hoạt động</p>
                    </div>
                </div>
                <button onclick="toggleChat()" class="text-white hover:text-red-200 transition-colors">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>
            </div>
            
            <div id="chat-messages" class="flex-1 p-4 overflow-y-auto bg-slate-50 flex flex-col gap-3 text-sm">
                <div class="flex items-start gap-2">
                    <img src="/assets/logodoan.png" class="w-6 h-6 object-contain flex-shrink-0 mt-1">
                    <div class="bg-white p-3 rounded-2xl rounded-tl-none shadow-sm border border-slate-100 text-slate-700">
                        Chào bạn! Mình là trợ lý AI của Đoàn Phường Tân Lập. Bạn cần hỗ trợ thông tin gì về các thủ tục, hoạt động hay địa điểm ạ?
                    </div>
                </div>
            </div>

            <div class="p-3 bg-white border-t border-slate-100 flex items-center gap-2">
                <input type="text" id="chat-input" placeholder="Nhập câu hỏi của bạn..." class="flex-1 bg-slate-100 text-slate-800 rounded-full px-4 py-2 focus:outline-none focus:ring-2 focus:ring-brand-blue/30 text-sm" onkeypress="handleEnter(event)">
                <button onclick="sendMessage()" id="send-btn" class="w-9 h-9 rounded-full bg-brand-blue text-white flex items-center justify-center hover:bg-blue-700 transition-colors flex-shrink-0">
                    <i class="fa-solid fa-paper-plane text-xs -ml-0.5"></i>
                </button>
            </div>
        </div>

        <div id="chat-greeting" class="absolute bottom-20 right-0 w-64 sm:w-[280px] bg-white p-3 sm:p-4 rounded-2xl rounded-br-none shadow-[0_10px_40px_rgba(0,0,0,0.15)] border border-slate-100 transform translate-y-6 opacity-0 transition-all duration-700 pointer-events-none flex items-start gap-3 z-40">
            <img src="/assets/logodoan.png" class="w-8 h-8 object-contain shrink-0 mt-0.5">
            <p class="text-[13px] sm:text-sm text-slate-700 leading-relaxed font-medium">Chào bạn! Mình là Trợ lý ảo của Đoàn Phường. Mình có thể giúp gì cho bạn hôm nay?</p>
        </div>

        <button onclick="toggleChat()" id="chat-toggle-btn" class="relative w-16 h-16 hover:scale-110 transition-transform duration-300 drop-shadow-xl focus:outline-none flex items-center justify-center bg-transparent mt-2">
            <img src="/assets/logodoan.png" alt="Chat" class="w-full h-full object-contain relative z-10">
            
            <span class="absolute top-0 right-0 z-20 flex h-4 w-4">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-4 w-4 bg-green-500 border-2 border-white"></span>
            </span>
        </button>
    </div>

    <script is:inline>
        const chatWindow = document.getElementById('chat-window');
        const chatMessages = document.getElementById('chat-messages');
        const chatInput = document.getElementById('chat-input');
        const sendBtn = document.getElementById('send-btn');
        const chatGreeting = document.getElementById('chat-greeting');

        // ==========================================
        // XỬ LÝ HIỆU ỨNG LỜI CHÀO KHI MỞ TRANG WEB
        // ==========================================
        document.addEventListener("DOMContentLoaded", () => {
            // Hiện bong bóng lời chào sau 1.5 giây
            setTimeout(() => {
                chatGreeting.classList.remove('translate-y-6', 'opacity-0');
                chatGreeting.classList.add('translate-y-0', 'opacity-100');
            }, 1500);

            // Tự động ẩn đi sau 5 giây (Tổng cộng là 6.5s)
            setTimeout(() => {
                chatGreeting.classList.remove('translate-y-0', 'opacity-100');
                chatGreeting.classList.add('translate-y-6', 'opacity-0');
            }, 6500);
        });

        // ==========================================
        // XỬ LÝ MỞ/ĐÓNG KHUNG CHAT
        // ==========================================
        function toggleChat() {
            // Nếu bong bóng lời chào đang hiện thì ép nó ẩn đi luôn
            if (chatGreeting) {
                chatGreeting.classList.remove('translate-y-0', 'opacity-100');
                chatGreeting.classList.add('translate-y-6', 'opacity-0');
            }

            if (chatWindow.classList.contains('hidden')) {
                chatWindow.classList.remove('hidden');
                setTimeout(() => {
                    chatWindow.classList.remove('scale-95', 'opacity-0');
                    chatWindow.classList.add('scale-100', 'opacity-100');
                }, 10);
                setTimeout(() => chatInput.focus(), 300); // Tự động trỏ chuột vào ô nhập liệu
            } else {
                chatWindow.classList.remove('scale-100', 'opacity-100');
                chatWindow.classList.add('scale-95', 'opacity-0');
                setTimeout(() => { chatWindow.classList.add('hidden'); }, 300);
            }
        }

        // ==========================================
        // XỬ LÝ NHẬN GỬI TIN NHẮN
        // ==========================================
        function handleEnter(e) {
            if (e.key === 'Enter') sendMessage();
        }

       async function sendMessage() {
            const message = chatInput.value.trim();
            if (!message) return;

            // --- ĐOẠN MỚI THÊM: GOM DATA TỪ GIAO DIỆN WEB CHO AI ĐỌC ---
            let webLocations = "";
            if (typeof ASSETS !== 'undefined') {
                const allPlaces = [
                    ...(ASSETS.coQuanNhaNuoc || []),
                    ...(ASSETS.diemVanHoa || []),
                    ...(ASSETS.diemHoiTruong || [])
                ];
                allPlaces.forEach(p => {
                    if (p.title || p.badge) {
                        webLocations += `- Cơ sở: ${p.title || p.badge} | Địa chỉ: ${p.address || 'Đang cập nhật'} | Link bản đồ: ${p.mapLink || ''}\n`;
                    }
                });
            }
            // -------------------------------------------------------------

            // 1. Hiển thị tin nhắn người dùng
            chatInput.value = '';
            chatInput.disabled = true;
            sendBtn.disabled = true;
            
            chatMessages.innerHTML += `
                <div class="flex items-start gap-2 justify-end">
                    <div class="bg-brand-blue text-white p-3 rounded-2xl rounded-tr-none shadow-sm max-w-[85%]">${message}</div>
                </div>`;
            chatMessages.scrollTop = chatMessages.scrollHeight;

            // 2. Hiện trạng thái AI đang gõ
            const typingId = 'typing-' + Date.now();
            chatMessages.innerHTML += `
                <div id="${typingId}" class="flex items-start gap-2">
                    <img src="/assets/logodoan.png" class="w-6 h-6 object-contain flex-shrink-0 mt-1">
                    <div class="bg-white p-3 rounded-2xl rounded-tl-none shadow-sm border border-slate-100 text-slate-500 flex gap-1">
                        <span class="animate-bounce">.</span><span class="animate-bounce" style="animation-delay: 0.1s">.</span><span class="animate-bounce" style="animation-delay: 0.2s">.</span>
                    </div>
                </div>`;
            chatMessages.scrollTop = chatMessages.scrollHeight;

            // 3. Gửi lên Cloudflare API (Kèm theo dữ liệu webLocations)
            try {
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: message, webData: webLocations }) // <-- Truyền thêm data web ở đây
                });
                const data = await response.json();
                
                // 4. Hiển thị câu trả lời AI
                document.getElementById(typingId).remove();
                chatMessages.innerHTML += `
                    <div class="flex items-start gap-2">
                        <img src="/assets/logodoan.png" class="w-6 h-6 object-contain flex-shrink-0 mt-1">
                        <div class="bg-white p-3 rounded-2xl rounded-tl-none shadow-sm border border-slate-100 text-slate-700 max-w-[85%] whitespace-pre-wrap leading-relaxed">${data.reply}</div>
                    </div>`;
            } catch (error) {
                document.getElementById(typingId).remove();
                chatMessages.innerHTML += `
                    <div class="flex items-start gap-2 text-red-500 text-xs text-center justify-center mt-2">Lỗi kết nối. Vui lòng thử lại.</div>`;
            }

            chatMessages.scrollTop = chatMessages.scrollHeight;
            chatInput.disabled = false;
            sendBtn.disabled = false;
            chatInput.focus();
        }
    </script>
</body>
</html>
