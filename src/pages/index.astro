            <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center w-9 h-9 min-[375px]:w-10 min-[375px]:h-10 rounded-full bg-white/10 border border-white/20 text-white hover:bg-white/20 transition-colors focus:outline-none ml-1 flex-shrink-0">
                <i id="mobile-menu-icon" class="fa-solid fa-bars text-base min-[375px]:text-lg"></i>
            </button>
        </div>

        <div id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-white shadow-2xl border-t border-gray-100 flex-col md:hidden z-50">
            <a href="#nhanuoc" class="mobile-link block px-6 py-4 text-brand-dark font-bold border-b border-gray-100 hover:bg-brand-light transition-colors flex items-center gap-3"><i class="fa-solid fa-landmark text-brand-blue w-5"></i> Cơ Quan Nhà Nước</a>
            <a href="#vanhoa" class="mobile-link block px-6 py-4 text-brand-dark font-bold border-b border-gray-100 hover:bg-brand-light transition-colors flex items-center gap-3"><i class="fa-solid fa-landmark text-brand-blue w-5"></i> Các Điểm Văn Hóa</a>
            <a href="#to-dan-pho" class="mobile-link block px-6 py-4 text-brand-dark font-bold hover:bg-brand-light transition-colors flex items-center gap-3"><i class="fa-solid fa-map-location-dot text-brand-blue w-5"></i> Hội Trường TDP & Buôn</a>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-12 space-y-20 relative z-20">
        <section id="nhanuoc" class="scroll-mt-24">
